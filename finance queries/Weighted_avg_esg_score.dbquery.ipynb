    "-- Weighting ESG scores by the amount of capital at risk\n",
    "\n",
    "SELECT\n",
    "  ROUND(SUM(esg_score * amount_invested_eur) / SUM(amount_invested_eur),2) AS weighted_avg_esg\n",
